# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# Postgres credentials — must match docker-compose.yml
DB_USER=optimizer
DB_PASSWORD=optimizer
DB_NAME=optimizer

# Full async connection string used by the application
# Local dev default (Postgres runs on host port 5433 via Docker)
DATABASE_URL=postgresql+asyncpg://optimizer:optimizer@localhost:5433/optimizer

# Schwab OAuth credentials
# Register your app at https://developer.schwab.com
# Callback URL must be registered there too; HTTPS is required by Schwab.
SCHWAB_CLIENT_ID=your_client_id
SCHWAB_CLIENT_SECRET=your_client_secret
SCHWAB_CALLBACK_URL=https://127.0.0.1:5000/callback

# FRED API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_key
